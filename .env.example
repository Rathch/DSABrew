# Kopiere nach `.env` im Repo-Root: `cp .env.example .env`
# Die API (`npm run start` / `npm run dev` in `server/`) lädt `.env` per Node `--import ./src/load-dotenv.mjs` vor dem Rest.
# Nicht committen — `.env` steht in `.gitignore`.

# --- API (siehe docs/hosting.md) — Referenz wie brew.rath-ulrich.de (Apache → 127.0.0.1:3001) ---
PORT=3001
# Lokal (ohne Docker): server/data/dsabrew.db
# In Docker-Prod via Compose-Override auf /data/dsabrew.db (persistentes Volume)
SQLITE_PATH=/data/dsabrew.db
# Nur lokal bei Hänger beim SQLite-Open: frische DB in /tmp (keine Persistenz über Neustarts)
# DSABREW_USE_TEMP_SQLITE=1
PUBLIC_ORIGIN=https://brew.rath-ulrich.de
TRUST_PROXY=1
RATE_POST_CREATE_PER_HOUR=10
RATE_PUT_PER_HOUR=120
RATE_PUT_BURST_PER_MIN=60

# --- TTL: Löschen unveränderter Standard-Dokumente (FR-023b) ---
DEFAULT_DOC_TTL_HOURS=24

# --- Betriebsmails (leer = keine Mails; auf dem Server Secrets setzen) ---
OPS_ALERT_EMAIL=
OPS_WEEKLY_REPORT_EMAIL=

# --- Passwortgeschützte Betriebsstatusseite (optional; Alternative/Ergänzung zu SMTP) ---
# Wenn gesetzt: GET /api/ops/status (HTTP Basic: OPS_STATUS_USER / OPS_STATUS_PASSWORD)
# JSON oder ?format=html bzw. Accept: text/html
OPS_STATUS_USER=ops
OPS_STATUS_PASSWORD=

# --- SQLite-Größe ---
SQLITE_SIZE_ALERT_BYTES=2147483648
SQLITE_SIZE_CHECK_MS=3600000

# --- Wöchentlicher Report ---
OPS_TIMEZONE=Europe/Berlin
WEEKLY_REPORT_WEEKDAY=1
WEEKLY_REPORT_HOUR=8

# --- SMTP (lokal meist leer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Logging (FR-030) ---
LOG_DIR=server/logs
LOG_LEVEL=info
LOG_MAX_SIZE=10M
LOG_MAX_FILES=14
# Produktion oft nur Datei; lokal `1` oder Zeile löschen = zusätzlich stdout
LOG_TO_STDOUT=0

# --- Missbrauchssperre (FR-035) ---
ABUSE_DOC_CREATE_MAX=500
ABUSE_DOC_CREATE_WINDOW_MS=600000
ABUSE_MAINTENANCE_COOLDOWN_MS=900000
