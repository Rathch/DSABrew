# Kopiere diese Datei nach `.env` und setze die Werte für dein Deployment.
# `.env` ist nicht im Repository — nur diese Vorlage.

# --- API (siehe docs/hosting.md) ---
# PORT=3001
# SQLITE_PATH=server/data/dsabrew.db
# PUBLIC_ORIGIN=https://example.com
# TRUST_PROXY=1
# RATE_POST_CREATE_PER_HOUR=10
# RATE_PUT_PER_HOUR=120
# RATE_PUT_BURST_PER_MIN=60

# --- TTL: Löschen unveränderter Standard-Dokumente (FR-023b) ---
# DEFAULT_DOC_TTL_HOURS=24

# --- Betriebsmails: Empfänger (SQLite-Alarm, wöchentlicher Report) ---
# OPS_ALERT_EMAIL=ops@example.com
# Optional: nur Wochenreport (sonst OPS_ALERT_EMAIL)
# OPS_WEEKLY_REPORT_EMAIL=

# --- SQLite-Größe: Warnmail einmal beim Überschreiten (Standard 2 GiB) ---
# SQLITE_SIZE_ALERT_BYTES=2147483648
# SQLITE_SIZE_CHECK_MS=3600000

# --- Wöchentlicher Report: Montag 08:00 Europe/Berlin ---
# OPS_TIMEZONE=Europe/Berlin
# WEEKLY_REPORT_WEEKDAY=1
# WEEKLY_REPORT_HOUR=8

# --- SMTP ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Logging: Dateien mit Rotation, keine Tokens/IPs in Logs (FR-030) ---
# LOG_DIR=server/logs
# LOG_LEVEL=info
# LOG_MAX_SIZE=10m
# LOG_MAX_FILES=14
# Nur Datei-Logs: LOG_TO_STDOUT=0
# LOG_TO_STDOUT=

# --- Missbrauchssperre: Neuanlage blocken, bestehende URLs nutzbar (FR-035) ---
# ABUSE_DOC_CREATE_MAX=500
# ABUSE_DOC_CREATE_WINDOW_MS=600000
# ABUSE_MAINTENANCE_COOLDOWN_MS=900000
