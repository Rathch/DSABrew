#!/usr/bin/env sh
# Schnell: ESLint + TS (web/shared/server) + Stylelint + Server-Typecheck — entspricht CI ohne Tests/Build/Audit.
set -e
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT" || exit 1
# shellcheck disable=SC1091
. "$REPO_ROOT/scripts/husky-env.sh"

if command -v npm >/dev/null 2>&1; then
  npm run ci:precommit
else
  # shellcheck disable=SC1091
  . "$REPO_ROOT/scripts/husky-wsl.sh"
  husky_run_in_wsl "npm run ci:precommit"
fi
