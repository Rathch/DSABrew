{
  "name": "dsabrew-web",
  "version": "0.38.2",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:integration": "VITE_PUBLIC_API_BASE=http://127.0.0.1:3001 npm run build && playwright test --config playwright.integration.config.ts",
    "test:e2e:integration:ci": "playwright test --config playwright.integration.config.ts",
    "prepare-assets": "node scripts/export-banner.mjs && node scripts/copy-parchment-assets.mjs && node scripts/slice-gm-frame.mjs",
    "import-gm-frame": "node scripts/import-gm-meister-frame.mjs",
    "predev": "npm run prepare-assets",
    "prebuild": "npm run prepare-assets",
    "postinstall": "npm run prepare-assets",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:ts": "npm run lint:ts --prefix ..",
    "lint:ts:fix": "npm run lint:ts:fix --prefix .."
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.50.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.8.9",
    "sharp": "^0.33.5",
    "stylelint": "^16.14.1",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.9.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "glob": "^13.0.0"
  }
}
